# HA Vibecode Agent — Standalone Mode Configuration
# Copy this file to .env and fill in your values

# Required: Home Assistant URL (no trailing slash)
HA_URL=http://192.168.1.100:8123

# Required: Long-Lived Access Token
# Create one in HA UI: Profile (bottom-left) -> Long-Lived Access Tokens -> Create Token
HA_TOKEN=your_long_lived_access_token_here

# Required: Path to your Home Assistant config directory on the host
HA_CONFIG_PATH=/path/to/homeassistant/config

# Optional: Agent port (default: 8099)
PORT=8099

# Optional: Log level (default: info)
LOG_LEVEL=info

# Optional: Auto git versioning (default: true)
GIT_VERSIONING_AUTO=true

# Optional: Max git backup commits (default: 30)
MAX_BACKUPS=30
